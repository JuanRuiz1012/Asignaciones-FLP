;; Unparse JHORMAN RICARDO LOAIZA
;; ============================================================

;; unparse-lista : (Listof T) x (T -> String) x String -> String
;; Propósito: convierte una lista a string con separador dado.
(define unparse-lista
  (lambda (lst fn sep)
    (if (null? lst)
        ""
        (apply string-append
               (cons (fn (car lst))
                     (map (lambda (x) (string-append sep (fn x)))
                          (cdr lst)))))))

;; unparse-prim : primitiva -> String
;; Propósito: convierte una primitiva AST a su símbolo textual.
(define unparse-prim
  (lambda (prim)
    (cases primitiva prim
      (sum-prim ()       "+")
      (minus-prim ()     "-")
      (mult-prim ()      "*")
      (div-prim ()       "/")
      (mod-prim ()       "%")
      (mayorigual-prim () ">=")
      (menorigual-prim () "<=")
      (mayor-prim ()     ">")
      (menor-prim ()     "<")
      (igual-prim ()     "==")
      (distinto-prim ()  "!=")
      (and-prim ()       "and")
      (or-prim ()        "or")
      (not-prim ()       "not")
      (concat-prim ()    "concat")
      (length-prim ()    "length")
      (tostring-prim ()  "to-string")
      (tonumber-prim ()  "to-number"))))

;; unparse-pat : patron -> String
;; Propósito: convierte un patrón AST a texto fuente.
(define unparse-pat
  (lambda (p)
    (cases patron p
      (num-pat (n)        (number->string n))
      (str-pat (s)        (string-append "\"" s "\""))
      (true-pat ()        "true")
      (false-pat ()       "false")
      (empty-stream-pat () "empty-stream")
      (wildcard-pat ()    "_")
      (stream-pat (h t)
        (string-append "stream(" (unparse-pat h) ", " (unparse-pat t) ")"))
      (ctor-pat (nombre subpats)
        (string-append (symbol->string nombre)
                       "(" (unparse-lista subpats unparse-pat ", ") ")"))
      (var-pat (id)       (symbol->string id)))))

;; unparse-exp : expresion -> String
;; Propósito: convierte una expresión AST a texto fuente de StreamLang-UV.
(define unparse-exp
  (lambda (exp)
    (cases expresion exp

      (num-exp (n)    (number->string n))
      (float-exp (f)  (number->string f))
      (str-exp (s)    (string-append "\"" s "\""))
      (char-exp (c)   (string-append "'" c "'"))
      (true-exp ()    "true")
      (false-exp ()   "false")
      (void-exp ()    "void")
      (empty-stream-exp () "empty-stream")
      (var-exp (id)   (symbol->string id))

      (let-exp (id1 rand1 ids rands body)
        (string-append
         "let " (symbol->string id1) " = " (unparse-exp rand1)
         (apply string-append
                (map (lambda (i r)
                       (string-append ", " (symbol->string i)
                                      " = " (unparse-exp r)))
                     ids rands))
         " in " (unparse-exp body) " end"))

      (var-decl-exp (id1 rand1 ids rands body)
        (string-append
         "var " (symbol->string id1) " = " (unparse-exp rand1)
         (apply string-append
                (map (lambda (i r)
                       (string-append ", " (symbol->string i)
                                      " = " (unparse-exp r)))
                     ids rands))
         " in " (unparse-exp body) " end"))

      (set-exp (id val)
        (string-append "set " (symbol->string id) " := " (unparse-exp val)))

      (freeze-exp (id)
        (string-append "freeze " (symbol->string id)))

      (begin-exp (e1 resto)
        (string-append
         "begin " (unparse-exp e1)
         (apply string-append
                (map (lambda (e) (string-append "; " (unparse-exp e))) resto))
         " end"))

      (if-exp (cond1 then1 elif-conds elif-thens else-e)
        (string-append
         "if " (unparse-exp cond1) " then " (unparse-exp then1)
         (apply string-append
                (map (lambda (c t)
                       (string-append " elif " (unparse-exp c)
                                      " then " (unparse-exp t)))
                     elif-conds elif-thens))
         " else " (unparse-exp else-e) " end"))

      (prim-exp (prim args)
        (string-append
         (unparse-prim prim)
         "(" (unparse-lista args unparse-exp ", ") ")"))

      (proc-exp (ids body)
        (string-append
         "proc(" (unparse-lista ids
                                (lambda (i) (symbol->string i)) ", ")
         ") " (unparse-exp body) " end"))

      (app-exp (rator rands)
        (string-append
         "apply " (unparse-exp rator)
         "(" (unparse-lista rands unparse-exp ", ") ")"))

      (letrec-exp (name1 ids1 body1 names idss bodies cuerpo)
        (string-append
         "letrec "
         (symbol->string name1)
         "(" (unparse-lista ids1 (lambda (i) (symbol->string i)) ", ") ") = "
         (unparse-exp body1)
         (apply string-append
                (map (lambda (n i b)
                       (string-append
                        "\n" (symbol->string n)
                        "(" (unparse-lista i (lambda (x) (symbol->string x)) ", ") ") = "
                        (unparse-exp b)))
                     names idss bodies))
         " in " (unparse-exp cuerpo) " end"))

      (stream-cons-exp (head tail)
        (string-append "stream(" (unparse-exp head)
                       ", " (unparse-exp tail) ")"))

      (head-exp (s)
        (string-append "head(" (unparse-exp s) ")"))

      (tail-exp (s)
        (string-append "tail(" (unparse-exp s) ")"))

      (stream-null-exp (s)
        (string-append "stream-null?(" (unparse-exp s) ")"))

      (match-exp (val pats exps)
        (string-append
         "match " (unparse-exp val) " with"
         (apply string-append
                (map (lambda (p e)
                       (string-append "\n| " (unparse-pat p)
                                      " => " (unparse-exp e)))
                     pats exps))
         "\nend"))

      (map-exp (f s)
        (string-append "map(" (unparse-exp f) ", " (unparse-exp s) ")"))

      (filter-exp (pred s)
        (string-append "filter(" (unparse-exp pred) ", " (unparse-exp s) ")"))

      (take-exp (n s)
        (string-append "take(" (unparse-exp n) ", " (unparse-exp s) ")"))

      (zip-with-exp (f s1 s2)
        (string-append "zip-with(" (unparse-exp f) ", "
                       (unparse-exp s1) ", " (unparse-exp s2) ")"))

      (ctor-exp (nombre args)
        (string-append
         (symbol->string nombre)
         "(" (unparse-lista args unparse-exp ", ") ")"))
      )))

;; unparse-variante : variante -> String
;; Propósito: convierte una variante de tipo algebraico a texto.
(define unparse-variante
  (lambda (v)
    (cases variante v
      (a-variant (nombre campos)
        (string-append
         (symbol->string nombre)
         "(" (unparse-lista campos
                             (lambda (c) (symbol->string c)) ", ") ")")))))

;; unparse-decl : decl-tipo -> String
;; Propósito: convierte una declaración de datatype a texto.
(define unparse-decl
  (lambda (d)
    (cases decl-tipo d
      (a-datatype-decl (nombre primera resto)
        (string-append
         "datatype " (symbol->string nombre) " = "
         (unparse-variante primera)
         (apply string-append
                (map (lambda (v)
                       (string-append " | " (unparse-variante v)))
                     resto))
         "\n")))))

;; unparse : programa -> String
;; Propósito: punto de entrada — convierte cualquier AST a texto fuente.
(define unparse
  (lambda (pgm)
    (cases programa pgm
      (a-program (decls exp)
        (string-append
         (apply string-append (map unparse-decl decls))
         (unparse-exp exp))))))



;; scheme-value? : Any -> Boolean
;; Propósito: predicado de valores del lenguaje StreamLang-UV.
(define scheme-value?
  (lambda (v) #t))

;; Tipo de dato ambiente
(define-datatype ambiente ambiente?
  (ambiente-vacio)
  (ambiente-extendido
   (ids  (list-of symbol?))
   (vals (list-of scheme-value?))
   (env  ambiente?)))

;; apply-env : Ambiente x Symbol -> SchemeVal
;; Propósito: busca id en el ambiente con shadowing.
;; Lanza error si no existe.
(define apply-env
  (lambda (env id)
    (cases ambiente env
      (ambiente-vacio ()
        (eopl:error 'apply-env "Variable no ligada: ~s" id))
      (ambiente-extendido (ids vals old-env)
        (letrec
            ((buscar
              (lambda (ids vals)
                (cond
                  [(null? ids) (apply-env old-env id)]
                  [(equal? (car ids) id) (car vals)]
                  [else (buscar (cdr ids) (cdr vals))]))))
          (buscar ids vals))))))

;; ambiente-inicial : () -> Ambiente
;; Propósito: ambiente inicial vacío.
(define ambiente-inicial
  (lambda ()
    (ambiente-vacio)))


(require rackunit)
(require rackunit/text-ui)
(require "interprete-minilang.rkt")

;; run : String -> SchemeVal
;; Propósito: ejecuta un programa fuente de MiniLang y retorna su valor.
(define (run src)
  (evaluar-programa (parser src)))


;; ============================================================
;; PARTE 1 — Intérprete base
;; ============================================================

(define parte-1
  (test-suite
   "Parte 1 — Intérprete base"

   ;; ---- Scanner (5 ejemplos) ----
   (test-case "scanner: número entero positivo"
     (check-not-exn (lambda () (scanner "42"))))

   (test-case "scanner: número entero negativo"
     (check-not-exn (lambda () (scanner "-7"))))

   (test-case "scanner: número flotante"
     (check-not-exn (lambda () (scanner "3.14"))))

   (test-case "scanner: identificador"
     (check-not-exn (lambda () (scanner "miVar123"))))

   (test-case "scanner: expresión completa"
     (check-not-exn (lambda () (scanner "+(x, y)"))))

   ;; ---- Parser (5 ejemplos) ----
   (test-case "parser: literal numérico"
     (check-not-exn (lambda () (parser "42"))))

   (test-case "parser: variable"
     (check-not-exn (lambda () (parser "x"))))

   (test-case "parser: true y false"
     (check-not-exn (lambda () (parser "true")))
     (check-not-exn (lambda () (parser "false"))))

   (test-case "parser: prim-exp suma"
     (check-not-exn (lambda () (parser "+(1, 2, 3)"))))

   (test-case "parser: if-exp"
     (check-not-exn (lambda () (parser "if true then 1 else 2"))))

   ;; ---- lit-exp ----
   (test-case "lit-exp: entero positivo"
     (check-equal? (run "42") 42))

   (test-case "lit-exp: entero negativo"
     (check-equal? (run "-7") -7))

   (test-case "lit-exp: flotante positivo"
     (check-equal? (run "3.14") 3.14))

   (test-case "lit-exp: flotante negativo"
     (check-equal? (run "-2.5") -2.5))

   ;; ---- true-exp / false-exp ----
   (test-case "true-exp retorna #true"
     (check-equal? (run "true") #true))

   (test-case "false-exp retorna #false"
     (check-equal? (run "false") #false))

   ;; ---- var-exp con ambiente inicial ----
   (test-case "var-exp: x del ambiente inicial"
     (check-equal? (run "x") 4))

   (test-case "var-exp: y del ambiente inicial"
     (check-equal? (run "y") 2))

   (test-case "var-exp: z del ambiente inicial"
     (check-equal? (run "z") 5))

   ;; ---- prim-exp aritméticas n-arias ----
   (test-case "sum-prim n-aria"
     (check-equal? (run "+(1, 2, 3)") 6))

   (test-case "minus-prim n-aria"
     (check-equal? (run "-(10, 3, 2)") 5))

   (test-case "mult-prim n-aria"
     (check-equal? (run "*(2, 3, 4)") 24))

   (test-case "div-prim binaria"
     (check-equal? (run "/(10, 2)") 5))

   (test-case "add1 unaria"
     (check-equal? (run "add1(5)") 6))

   (test-case "sub1 unaria"
     (check-equal? (run "sub1(5)") 4))

   ;; ---- prim-exp relacionales ----
   (test-case "mayor-prim verdadero"
     (check-equal? (run ">(5, 3)") #true))

   (test-case "mayor-prim falso"
     (check-equal? (run ">(3, 5)") #false))

   (test-case "mayorigual-prim"
     (check-equal? (run ">=(4, 4)") #true))

   (test-case "menor-prim"
     (check-equal? (run "<(2, 5)") #true))

   (test-case "menorigual-prim"
     (check-equal? (run "<=(5, 5)") #true))

   (test-case "igual-prim verdadero"
     (check-equal? (run "==(3, 3)") #true))

   (test-case "igual-prim falso"
     (check-equal? (run "==(3, 4)") #false))

   ;; ---- if-exp ----
   (test-case "if-exp rama true"
     (check-equal? (run "if true then 1 else 2") 1))

   (test-case "if-exp rama false"
     (check-equal? (run "if false then 1 else 2") 2))

   (test-case "if-exp con condición calculada"
     (check-equal? (run "if >(x, 2) then +(x, 1) else -(x, 1)") 5))

   (test-case "if-exp error si condición no es booleana"
     (check-exn exn:fail?
       (lambda () (run "if 1 then 2 else 3"))))

   ;; ---- let-exp ----
   (test-case "let-exp ligaduras paralelas"
     (check-equal? (run "let u = 1 v = 2 in +(u, v)") 3))

   (test-case "let-exp shadowing de x"
     (check-equal? (run "let x = 100 in x") 100))

   (test-case "let-exp usa ambiente exterior en rands"
     (check-equal? (run "let u = +(x, y) in u") 6))

   ;; ---- apply-env ----
   (test-case "apply-env: variable no ligada lanza error"
     (check-exn exn:fail?
       (lambda () (run "w"))))

   (test-case "apply-env: shadowing correcto"
     (check-equal? (run "let x = 99 in let x = 1 in x") 1))
   ))


;; ============================================================
;; PARTE 2 — Extensión de primitivas
;; ============================================================

(define parte-2
  (test-suite
   "Parte 2 — Primitivas nuevas"

   ;; ---- not-prim ----
   (test-case "not(true) = false"
     (check-equal? (run "not(true)") #false))

   (test-case "not(false) = true"
     (check-equal? (run "not(false)") #true))

   (test-case "not con expresión"
     (check-equal? (run "not(>(2, 5))") #true))

   (test-case "not: error si no es booleano"
     (check-exn exn:fail?
       (lambda () (run "not(1)"))))

   ;; ---- and-prim ----
   (test-case "and(true, true) = true"
     (check-equal? (run "and(true, true)") #true))

   (test-case "and(true, false) = false"
     (check-equal? (run "and(true, false)") #false))

   (test-case "and(false, false) = false"
     (check-equal? (run "and(false, false)") #false))

   ;; ---- or-prim ----
   (test-case "or(false, false) = false"
     (check-equal? (run "or(false, false)") #false))

   (test-case "or(true, false) = true"
     (check-equal? (run "or(true, false)") #true))

   (test-case "or(false, true) = true"
     (check-equal? (run "or(false, true)") #true))

   ;; ---- min-prim ----
   (test-case "min n-aria: tres números"
     (check-equal? (run "min(3, 1, 2)") 1))

   (test-case "min con un solo número"
     (check-equal? (run "min(7)") 7))

   (test-case "min con cinco números"
     (check-equal? (run "min(10, 4, 7, 1, 9)") 1))

   ;; ---- max-prim ----
   (test-case "max n-aria: tres números"
     (check-equal? (run "max(3, 1, 2)") 3))

   (test-case "max con un solo número"
     (check-equal? (run "max(7)") 7))

   (test-case "max con cinco números"
     (check-equal? (run "max(10, 4, 7, 1, 9)") 10))

   ;; ---- mod-prim ----
   (test-case "mod(10, 3) = 1"
     (check-equal? (run "mod(10, 3)") 1))

   (test-case "mod(12, 4) = 0"
     (check-equal? (run "mod(12, 4)") 0))

   (test-case "mod(7, 5) = 2"
     (check-equal? (run "mod(7, 5)") 2))

   ;; ---- pow-prim ----
   (test-case "pow(2, 10) = 1024"
     (check-equal? (run "pow(2, 10)") 1024))

   (test-case "pow(3, 3) = 27"
     (check-equal? (run "pow(3, 3)") 27))

   (test-case "pow(5, 0) = 1"
     (check-equal? (run "pow(5, 0)") 1))
   ))


;; ============================================================
;; PARTE 3 — Extensión de expresiones
;; ============================================================

(define parte-3
  (test-suite
   "Parte 3 — Expresiones nuevas"

   ;; ---- cond-exp ----
   (test-case "cond-exp: primera condición verdadera"
     (check-equal?
      (run "cond >(x, 10) ==> +(x, 1) ==(x, 4) ==> *(x, 2) else ==> 0 end")
      8))

   (test-case "cond-exp: segunda condición verdadera"
     (check-equal?
      (run "cond >(x, 10) ==> 99 <(x, 10) ==> +(x, 1) else ==> 0 end")
      5))

   (test-case "cond-exp: cae en else"
     (check-equal?
      (run "cond >(x, 10) ==> 1 <(x, 3) ==> 2 else ==> 0 end")
      0))

   (test-case "cond-exp: resultado del else es expresión"
     (check-equal?
      (run "cond false ==> 1 else ==> +(x, y) end")
      6))

   (test-case "cond-exp: condición no booleana lanza error"
     (check-exn exn:fail?
       (lambda ()
         (run "cond 1 ==> 2 else ==> 3 end"))))

   ;; ---- let*-exp ----
   (test-case "let*-exp: ligaduras secuenciales clásico"
     (check-equal?
      (run "let* p = 3 q = +(p, 5) r = *(q, p) in r")
      24))

   (test-case "let*-exp: cada ligadura ve la anterior"
     (check-equal?
      (run "let* a = 10 b = +(a, 5) in b")
      15))

   (test-case "let*-exp: sin ligaduras evalúa el cuerpo directo"
     (check-equal?
      (run "let* in +(x, y)")
      6))

   (test-case "let*-exp: tres niveles de dependencia"
     (check-equal?
      (run "let* i = 1 j = +(i, 1) k = +(j, 1) in +(i, j, k)")
      6))

   (test-case "let*-exp: shadowing en ligaduras secuenciales"
     (check-equal?
      (run "let* x = 10 x = +(x, 5) in x")
      15))

   ;; ---- unless-exp ----
   (test-case "unless-exp: condición false ejecuta then"
     (check-equal? (run "unless false then 1 else 2") 1))

   (test-case "unless-exp: condición true ejecuta else"
     (check-equal? (run "unless true then 1 else 2") 2))

   (test-case "unless-exp: con condición calculada false"
     (check-equal? (run "unless >(x, 100) then +(x, 1) else -(x, 1)") 5))

   (test-case "unless-exp: con condición calculada true"
     (check-equal? (run "unless <(x, 100) then +(x, 1) else -(x, 1)") 3))

   (test-case "unless-exp: condición no booleana lanza error"
     (check-exn exn:fail?
       (lambda () (run "unless 1 then 2 else 3"))))
   ))


;; ============================================================
;; Ejecución
;; ============================================================

(module+ test
  (run-tests parte-1)
  (run-tests parte-2)
  (run-tests parte-3))
#lang eopl

; ============================================================
; Taller 1 - Abstracción de datos y programas
; Representación de maps usando DATATYPES
; Fundamentos de Interpretación y Compilación de Lenguajes
; ============================================================

#|
Gramática:

<map>   ::= '()                    empty-map()
        ::= <entry> <map>          non-empty-map(ent, mp)

<entry> ::= <key> <value>          entry(k, v)

<key>   ::= <int>                  key-int(i)
        ::= <symbol>               key-sym(s)

<value> ::= <int>                  val-int(i)
        ::= <symbol>               val-sym(s)
        ::= <lint>                 val-lint(lst)
        ::= <lsym>                 val-lsym(lst)

<lint>  ::= '()                    empty-lint()
        ::= <int> <lint>           non-empty-lint(num, lst)

<lsym>  ::= '()                    empty-lsym()
        ::= <symbol> <lsym>        non-empty-lsym(sym, lst)
|#

; ============================================================
; Definición de datatypes
; ============================================================

; Tipo lint: lista de enteros
(define-datatype lint lint?
  (empty-lint)
  (non-empty-lint
   (num number?)
   (lst lint?)))

; Tipo lsym: lista de símbolos
(define-datatype lsym lsym?
  (empty-lsym)
  (non-empty-lsym
   (sym symbol?)
   (lst lsym?)))

; Tipo key: clave del map (entero o símbolo)
(define-datatype key key?
  (key-int (i number?))
  (key-sym (s symbol?)))

; Tipo value: valor del map
(define-datatype value value?
  (val-int  (i number?))
  (val-sym  (s symbol?))
  (val-lint (lst lint?))
  (val-lsym (lst lsym?)))

; Tipo entry: par clave-valor
(define-datatype entry entry?
  (an-entry
   (k key?)
   (v value?)))

; Tipo map: colección de entradas
(define-datatype map map?
  (empty-map)
  (non-empty-map
   (ent entry?)
   (mp  map?)))

; ============================================================
; Extractores (aliases con los nombres del enunciado)
; ============================================================

; entry->k: extrae la clave de una entrada
(define entry->k
  (lambda (e)
    (cases entry e
      (an-entry (k v) k))))

; entry->v: extrae el valor de una entrada
(define entry->v
  (lambda (e)
    (cases entry e
      (an-entry (k v) v))))

; non-empty-map->ent: extrae la primera entrada del map
(define non-empty-map->ent
  (lambda (m)
    (cases map m
      (empty-map () (eopl:error "non-empty-map->ent: map vacío"))
      (non-empty-map (ent mp) ent))))

; non-empty-map->mp: extrae el resto del map
(define non-empty-map->mp
  (lambda (m)
    (cases map m
      (empty-map () (eopl:error "non-empty-map->mp: map vacío"))
      (non-empty-map (ent mp) mp))))

; key-int->i: extrae el entero de una clave entera
(define key-int->i
  (lambda (k)
    (cases key k
      (key-int (i) i)
      (key-sym (s) (eopl:error "key-int->i: clave no es entera")))))

; key-sym->s: extrae el símbolo de una clave simbólica
(define key-sym->s
  (lambda (k)
    (cases key k
      (key-int (i) (eopl:error "key-sym->s: clave no es simbólica"))
      (key-sym (s) s))))

; val-int->i: extrae el entero de val-int
(define val-int->i
  (lambda (v)
    (cases value v
      (val-int (i) i)
      (else (eopl:error "val-int->i: valor no es entero")))))

; val-sym->s: extrae el símbolo de val-sym
(define val-sym->s
  (lambda (v)
    (cases value v
      (val-sym (s) s)
      (else (eopl:error "val-sym->s: valor no es simbólico")))))

; val-lint->lst: extrae la lista de val-lint
(define val-lint->lst
  (lambda (v)
    (cases value v
      (val-lint (lst) lst)
      (else (eopl:error "val-lint->lst: valor no es lista de enteros")))))

; val-lsym->lst: extrae la lista de val-lsym
(define val-lsym->lst
  (lambda (v)
    (cases value v
      (val-lsym (lst) lst)
      (else (eopl:error "val-lsym->lst: valor no es lista de símbolos")))))

; non-empty-lint->num: extrae el primer entero de lint
(define non-empty-lint->num
  (lambda (lst)
    (cases lint lst
      (empty-lint () (eopl:error "non-empty-lint->num: lista vacía"))
      (non-empty-lint (num rest) num))))

; non-empty-lint->lst: extrae el resto de lint
(define non-empty-lint->lst
  (lambda (lst)
    (cases lint lst
      (empty-lint () (eopl:error "non-empty-lint->lst: lista vacía"))
      (non-empty-lint (num rest) rest))))

; non-empty-lsym->sym: extrae el primer símbolo de lsym
(define non-empty-lsym->sym
  (lambda (lst)
    (cases lsym lst
      (empty-lsym () (eopl:error "non-empty-lsym->sym: lista vacía"))
      (non-empty-lsym (sym rest) sym))))

; non-empty-lsym->lst: extrae el resto de lsym
(define non-empty-lsym->lst
  (lambda (lst)
    (cases lsym lst
      (empty-lsym () (eopl:error "non-empty-lsym->lst: lista vacía"))
      (non-empty-lsym (sym rest) rest))))

; ============================================================
; Funciones auxiliares internas
; ============================================================

; unwrap-key: extrae el valor nativo de una clave
(define unwrap-key
  (lambda (k)
    (cases key k
      (key-int (i) i)
      (key-sym (s) s))))

; build-key: construye key según tipo nativo
(define build-key
  (lambda (k)
    (if (number? k)
        (key-int k)
        (key-sym k))))

; build-value: construye value según tipo nativo
(define build-value
  (lambda (v)
    (cond
      [(number? v) (val-int v)]
      [(symbol? v) (val-sym v)]
      [(and (list? v) (not (null? v)) (number? (car v)))
       (val-lint (list->lint v))]
      [(and (list? v) (not (null? v)) (symbol? (car v)))
       (val-lsym (list->lsym v))]
      [(null? v) (val-lint (empty-lint))]
      [else (eopl:error "build-value: tipo no soportado ~s" v)])))

; list->lint: convierte lista nativa en lint
(define list->lint
  (lambda (lst)
    (if (null? lst)
        (empty-lint)
        (non-empty-lint (car lst) (list->lint (cdr lst))))))

; list->lsym: convierte lista nativa en lsym
(define list->lsym
  (lambda (lst)
    (if (null? lst)
        (empty-lsym)
        (non-empty-lsym (car lst) (list->lsym (cdr lst))))))

; unwrap-value: extrae el valor nativo de un value
(define unwrap-value
  (lambda (v)
    (cases value v
      (val-int  (i)   i)
      (val-sym  (s)   s)
      (val-lint (lst) (lint->list lst))
      (val-lsym (lst) (lsym->list lst)))))

; lint->list: convierte lint en lista nativa
(define lint->list
  (lambda (lst)
    (cases lint lst
      (empty-lint () '())
      (non-empty-lint (num rest)
                      (cons num (lint->list rest))))))

; lsym->list: convierte lsym en lista nativa
(define lsym->list
  (lambda (lst)
    (cases lsym lst
      (empty-lsym () '())
      (non-empty-lsym (sym rest)
                      (cons sym (lsym->list rest))))))

; keys-equal?: compara dos claves nativas
(define keys-equal?
  (lambda (k1 k2)
    (equal? k1 k2)))

; rebuild-map: reconstruye el map desde acumulador
(define rebuild-map
  (lambda (mp acc)
    (if (null? acc)
        mp
        (rebuild-map (non-empty-map (car acc) mp) (cdr acc)))))

; ============================================================
; Funciones principales del map con cases
; ============================================================

; insert: map x clave-nativa x valor-nativo -> map
; Inserta o actualiza una entrada en el map.
; Si la clave ya existe, actualiza su valor; si no, la agrega.
(define insert
  (lambda (mp k v)
    (letrec
        ((insert-aux
          (lambda (mp k v acc)
            (cases map mp
              (empty-map ()
                         (rebuild-map
                          (non-empty-map (an-entry (build-key k) (build-value v))
                                         (empty-map))
                          acc))
              (non-empty-map (ent rest)
                             (let ((ent-key (unwrap-key (entry->k ent))))
                               (if (keys-equal? ent-key k)
                                   (rebuild-map
                                    (non-empty-map (an-entry (build-key k) (build-value v))
                                                   rest)
                                    acc)
                                   (insert-aux rest k v (cons ent acc)))))))))
      (insert-aux mp k v '()))))

; search: map x clave-nativa -> valor-nativo
; Busca la clave en el map y retorna su valor nativo.
; Si no se encuentra, genera un error.
(define search
  (lambda (mp k)
    (cases map mp
      (empty-map ()
                 (eopl:error "search: clave no encontrada ~s" k))
      (non-empty-map (ent rest)
                     (let ((ent-key (unwrap-key (entry->k ent))))
                       (if (keys-equal? ent-key k)
                           (unwrap-value (entry->v ent))
                           (search rest k)))))))

; delete: map x clave-nativa -> map
; Elimina la entrada con la clave dada del map.
; Si la clave no existe, genera un error.
(define delete
  (lambda (mp k)
    (letrec
        ((delete-aux
          (lambda (mp k acc found?)
            (cases map mp
              (empty-map ()
                         (if found?
                             (rebuild-map (empty-map) acc)
                             (eopl:error "delete: clave no encontrada ~s" k)))
              (non-empty-map (ent rest)
                             (let ((ent-key (unwrap-key (entry->k ent))))
                               (if (keys-equal? ent-key k)
                                   (delete-aux rest k acc #t)
                                   (delete-aux rest k (cons ent acc) found?))))))))
      (delete-aux mp k '() #f))))

; ============================================================
; provide para uso en tests
; ============================================================

(provide empty-map non-empty-map map?
         an-entry entry? entry->k entry->v
         non-empty-map->ent non-empty-map->mp
         key-int key-sym key? key-int? key-sym? key-int->i key-sym->s
         val-int val-sym val-lint val-lsym value?
         val-int->i val-sym->s val-lint->lst val-lsym->lst
         empty-lint non-empty-lint lint?
         non-empty-lint->num non-empty-lint->lst
         empty-lsym non-empty-lsym lsym?
         non-empty-lsym->sym non-empty-lsym->lst
         insert search delete)
